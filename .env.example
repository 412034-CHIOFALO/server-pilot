# ─────────────────────────────────────────
# Server Pilot — Variables de entorno
# Copiá este archivo a .env y completá los valores.
# El .env NUNCA debe commitearse al repositorio.
# ─────────────────────────────────────────

# Credenciales del panel web
SP_USER=admin
SP_PASS=changeme

# Conexión SSH al servidor a administrar
SP_SSH_HOST=192.168.1.10
SP_SSH_USER=ubuntu
SP_SSH_KEY=/root/.ssh/id_rsa

# Puerto del backend (por defecto 8090)
# SP_PORT=8090

# Ruta donde se persisten datos (settings, historial de métricas, audit log)
SP_DATA=/data

# Seguridad: intentos fallidos antes del lockout
# SP_MAX_ATTEMPTS=5
# SP_LOCK_MINUTES=15

# ── Stack de observabilidad (opcional) ──
# Usadas por docker-compose.observability.yml
# SP_USER y SP_PASS son reutilizadas para Grafana y Prometheus
